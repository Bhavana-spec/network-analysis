alert icmp any any -> any any (msg:"ICMP Traffic Detected"; sid:1000001; rev:1;)
alert http any any -> any any (msg:"HTTP Traffic Detected"; sid:1000002; rev:1;)
alert http any any -> any any (msg:"Login Submission Detected"; content:"username="; http_client_body; sid:1000003; rev:1;)
alert http any any -> any any (msg:"Possible XSS Attempt"; content:"<script>"; nocase; sid:1000004; rev:1;)
alert http any any -> any any (msg:"Possible SQL Injection Attempt"; content:"' OR 1=1"; nocase; sid:1000005; rev:1;)